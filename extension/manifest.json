{
  "manifest_version": 3,
  "name": "Tabby Connector",
  "description": "Pushes Chrome tab state to the Tabby app and executes tab actions — no DevTools attachment needed.",
  "version": "0.1.0",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["tabs", "storage", "alarms"],
  "host_permissions": ["http://localhost:3000/*", "http://127.0.0.1:3000/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tabby"
  }
}
